# Log level
LOG_LEVEL=INFO

# Application
ENVIRONMENT=production
API_PREFIX_STR=/api/v1
PROJECT_NAME=CogniBrew Vector Operation

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION=face_embeddings
EMBEDDING_DIM=512

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=vector-evolution

# Gallery / Baseline Update
MAX_VECTORS_PER_USER=10
UPPER_SIMILARITY_THRESHOLD=0.92
LOWER_SIMILARITY_THRESHOLD=0.75
EMA_ALPHA=0.1

# Per-Device Threshold Calibration
MIN_CALIBRATION_SAMPLES=10
FALLBACK_SIMILARITY_THRESHOLD=0.5